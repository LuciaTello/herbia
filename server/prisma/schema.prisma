// Prisma Schema: like your @Entity classes in JPA/Hibernate
// Each "model" becomes a table in PostgreSQL AND a TypeScript type

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Like @Entity User in JPA
// In Spring Security, this is often called "AppUser" to avoid conflicts
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique                        // Like @Column(unique = true)
  passwordHash String   @map("password_hash")          // NEVER store plain passwords!
  lang         String   @default("es")                  // "es" | "fr"
  username     String?  @unique
  points       Int      @default(0)
  photoUrl     String?  @map("photo_url")
  bio          String?
  trekTipCount Int @default(0) @map("mission_tip_count")
  createdAt    DateTime @default(now())

  // One-to-many: a user has many treks
  treks        Trek[]

  sentFriendships     Friendship[] @relation("sentFriendships")
  receivedFriendships Friendship[] @relation("receivedFriendships")

  @@map("users")
}

// A trek represents a search (origin → destination) with its suggested plants
model Trek {
  id          Int              @id @default(autoincrement())
  origin      String
  destination String
  description String           @default("")
  month       Int              // 1-12, for seasonal plant suggestions
  year        Int              // e.g. 2026
  createdAt   DateTime         @default(now())
  country     String?
  countryCode String?          @map("country_code")
  region      String?
  regionCode  String?          @map("region_code")
  originLat   Float?           @map("origin_lat")
  originLng   Float?           @map("origin_lng")
  destLat     Float?           @map("dest_lat")
  destLng     Float?           @map("dest_lng")
  status      String           @default("active")  // "active" | "completed"

  // Foreign key to User
  userId      Int              @map("user_id")
  user        User             @relation(fields: [userId], references: [id])

  // One-to-many: a trek has many suggested plants
  plants      SuggestedPlant[] @relation("trekPlants")

  // Plants that were originally found in this trek (reverse of foundInTrek)
  plantsFoundHere SuggestedPlant[] @relation("foundInTrek")

  @@map("treks")
}

// Canonical plant species (one row per species, shared across all treks)
model Plant {
  id             Int      @id @default(autoincrement())
  scientificName String   @unique @map("scientific_name")
  commonNameEs   String?  @map("common_name_es")
  commonNameFr   String?  @map("common_name_fr")
  genus          String   @default("")
  family         String   @default("")
  photoUrl       String?  @map("photo_url")       // lazy-filled
  photoSource    String?  @map("photo_source")     // "wikipedia" | "inaturalist"

  suggestedPlants SuggestedPlant[]

  @@index([family])
  @@index([genus])
  @@map("plants")
}

// A plant suggested by the AI for a specific trek
model SuggestedPlant {
  id             Int       @id @default(autoincrement())
  commonName     String
  scientificName String
  description    String
  hint           String    @default("")
  rarity         String    @default("common")
  genus          String    @default("")
  family         String    @default("")
  source         String    @default("ai")   // "ai" | "user"
  pendingSimilarity Int    @default(0)      @map("pending_similarity")
  found          Boolean   @default(false)
  foundAt        DateTime?

  // Link to canonical Plant (null for unidentified user-added plants)
  plantId        Int?      @map("plant_id")
  plant          Plant?    @relation(fields: [plantId], references: [id], onDelete: SetNull)

  // Trek where this plant was originally found (null if not found yet)
  foundInTrekId  Int?      @map("found_in_trek_id")
  foundInTrek    Trek?     @relation("foundInTrek", fields: [foundInTrekId], references: [id], onDelete: SetNull)

  // One-to-many: a plant has many photos
  photos         PlantPhoto[]

  // Foreign key to Trek
  trekId         Int       @map("trek_id")
  trek           Trek      @relation("trekPlants", fields: [trekId], references: [id], onDelete: Cascade)

  @@map("suggested_plants")
}

// A photo for a plant, fetched from Wikipedia or iNaturalist
model PlantPhoto {
  id         Int    @id @default(autoincrement())
  url        String
  source     String   // "wikipedia" | "inaturalist" | "user"
  similarity Int    @default(0)
  plantId    Int    @map("plant_id")
  plant      SuggestedPlant @relation(fields: [plantId], references: [id], onDelete: Cascade)

  @@map("plant_photos")
}

model Friendship {
  id         Int      @id @default(autoincrement())
  senderId   Int      @map("sender_id")
  receiverId Int      @map("receiver_id")
  status     String   @default("pending")  // "pending" | "accepted"
  createdAt  DateTime @default(now())

  sender   User @relation("sentFriendships", fields: [senderId], references: [id])
  receiver User @relation("receivedFriendships", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
  @@map("friendships")
}

// Daily usage counter for Google Maps API calls (free tier = $200/month)
model DailyQuota {
  date  DateTime @id @db.Date
  count Int      @default(0)

  @@map("daily_quota")
}
